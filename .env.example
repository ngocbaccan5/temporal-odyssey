# ── Environment ──────────────────────────────────────────────────────────────
# Set ENV=production on your host. Never commit real values.
ENV=development
# ENV=production

DEBUG=0
# DEBUG=1   ← local dev only; enables /docs, /redoc

# ── Secrets (generate fresh values — never reuse dev keys in production) ────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-plus-random-characters-NEVER-commit-real-value
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=replace-with-32-plus-random-characters-NEVER-commit-real-value

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite is fine. Production: PostgreSQL required.
DATABASE_URL=sqlite:///./temporal_odyssey.db
# DATABASE_URL=postgresql://user:password@host:5432/temporal_odyssey

# ── Allowed origins / hosts ───────────────────────────────────────────────────
# Production: set to your exact domain(s). No trailing slash.
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Dev: ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Dev: ALLOWED_HOSTS=localhost,127.0.0.1

TOKEN_EXPIRE_MINUTES=1440

# ── Seed / bootstrap (default OFF in production) ──────────────────────────────
# SEED_DEMO_USERS — creates datascience/tester accounts with known passwords.
#   Set to true ONLY in local dev / staging. NEVER in production.
SEED_DEMO_USERS=false

# ENABLE_ADMIN_BOOTSTRAP — creates an "admin" account on first startup.
#   Requires ADMIN_BOOTSTRAP_PASSWORD. NEVER leave enabled after first run.
ENABLE_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-random-password-then-disable

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace-with-gemini-api-key

# ── Optional tuning ──────────────────────────────────────────────────────────
API_RATE_LIMIT=120/minute
LOGIN_RATE_LIMIT=10/minute
REGISTER_RATE_LIMIT=5/minute
CHAT_RATE_LIMIT=15/minute
ADMIN_RATE_LIMIT=3/minute
DEBUG_HTTP_LOG=false
